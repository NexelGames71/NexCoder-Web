# NexCoder website environment example. Copy to .env.local for local overrides.
# These values are PUBLIC (NEXT_PUBLIC_*) and safe to expose in the browser.
# Do NOT put Cloudflare API tokens, R2 access keys, or account IDs here — the
# download Worker uses an R2 binding, not credentials.

# Same-origin in production (the Cloudflare Worker intercepts these paths).
# Endpoints are built per platform as:  <API_BASE>/api/download/<windows|macos|linux>
# Leave API_BASE empty in production for same-origin requests.
NEXT_PUBLIC_NEXCODER_API_BASE=

# For local development against the Worker dev server, point at it:
# NEXT_PUBLIC_NEXCODER_API_BASE=http://localhost:8787

# --- Supabase (auth) ---
# The publishable/anon key is PUBLIC by design (shipped to the browser); security
# comes from Row Level Security, not key secrecy. Keep real values in .env.local
# (gitignored) and add them in the Vercel project settings for production.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Optional Windows-only overrides (backward compatible; usually leave unset):
# NEXT_PUBLIC_NEXCODER_DOWNLOAD_ENDPOINT=/api/download/windows
# NEXT_PUBLIC_NEXCODER_RELEASES_ENDPOINT=/api/releases/windows
