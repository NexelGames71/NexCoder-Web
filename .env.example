# NexCoder website environment example. Copy to .env.local for local overrides.
# These values are PUBLIC (NEXT_PUBLIC_*) and safe to expose in the browser.
# Do NOT put Cloudflare API tokens, R2 access keys, or account IDs here — the
# download Worker uses an R2 binding, not credentials.

# Same-origin in production (the Cloudflare Worker intercepts these paths).
# Endpoints are built per platform as:  <API_BASE>/api/download/<windows|macos|linux>
# Leave API_BASE empty in production for same-origin requests.
NEXT_PUBLIC_NEXCODER_API_BASE=

# For local development against the Worker dev server, point at it:
# NEXT_PUBLIC_NEXCODER_API_BASE=http://localhost:8787

# --- Supabase (auth) ---
# The publishable/anon key is PUBLIC by design (shipped to the browser); security
# comes from Row Level Security, not key secrecy. Keep real values in .env.local
# (gitignored) and add them in the Vercel project settings for production.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
# Server-only. Required for Polar webhooks to update plans/subscriptions.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# --- Polar (payments) ---
# Create an Organization Access Token in Polar. Keep it server-side only.
POLAR_ACCESS_TOKEN=polar_oat_xxxxxxxxxxxxxxxxxxxx
# Set to sandbox while testing, then production for live checkout.
# POLAR_SERVER=sandbox
POLAR_SERVER=production
# Optional override if needed:
# POLAR_API_BASE_URL=https://api.polar.sh

# In Polar, create a Raw webhook endpoint:
# https://nexcoder.trynexa-ai.com/api/webhook/polar
# Paste the generated signing secret here.
POLAR_WEBHOOK_SECRET=polar_whs_xxxxxxxxxxxxxxxxxxxx

# Public canonical app URL used for checkout success/return URLs.
NEXT_PUBLIC_SITE_URL=https://nexcoder.trynexa-ai.com

# Polar recurring product IDs. Fill these from the Polar product dashboard.
POLAR_PRODUCT_PLUS_MONTHLY=
POLAR_PRODUCT_PLUS_YEARLY=
POLAR_PRODUCT_PRO_MONTHLY=
POLAR_PRODUCT_PRO_YEARLY=
POLAR_PRODUCT_PREMIUM_MONTHLY=
POLAR_PRODUCT_PREMIUM_YEARLY=
POLAR_PRODUCT_BUSINESS_STANDARD_MONTHLY=
POLAR_PRODUCT_BUSINESS_STANDARD_YEARLY=
POLAR_PRODUCT_BUSINESS_PLUS_MONTHLY=
POLAR_PRODUCT_BUSINESS_PLUS_YEARLY=

# Optional Windows-only overrides (backward compatible; usually leave unset):
# NEXT_PUBLIC_NEXCODER_DOWNLOAD_ENDPOINT=/api/download/windows
# NEXT_PUBLIC_NEXCODER_RELEASES_ENDPOINT=/api/releases/windows
